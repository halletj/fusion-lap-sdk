AdditiveFEADeckBuilder : Base
  cards: AdditiveFEADeckBuilderCard]
  append(card: AdditiveFEADeckBuilderCard) -> void
  @static create() -> AdditiveFEADeckBuilder
  createBuildPlateXYExtensionCard(left: float, right: float, front: float, back: float) -> AdditiveFEADeckBuilderCard
