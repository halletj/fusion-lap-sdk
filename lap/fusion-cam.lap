CAMAdditiveBuildExportOptions : CAMExportOptions
  exportFilters: CAMAdditiveBuildExportFilter]
  selectedExportFilterId: str

CAMAdditiveContainer : OperationBase
  allOperations: ObjectCollection
  children: ChildOperationList
  parent: Base
  copyAfter(operation: OperationBase) -> bool
  copyBefore(operation: OperationBase) -> bool
  copyInto(container: OperationBase) -> bool
  deleteMe() -> bool
  duplicate() -> bool
  hasMissingReferences() -> bool
  modifyUtility(utility: ModifyUtilityTypes) -> ModifyUtility
  moveAfter(operation: OperationBase) -> bool
  moveBefore(operation: OperationBase) -> bool
  moveInto(container: OperationBase) -> bool
  removeReferences(entity: Base, removeFromChildren: bool) -> bool

CAMArrangeParameterValue : ParameterValue
  applyArrangeSelections(arrangeSelections: ArrangeSelections) -> void
  getArrangeSelections() -> ArrangeSelections

CAMAutodeskCLDExportOptions : CAMExportOptions

CAMAutodeskCLDImportOptions : CAMImportOptions
  # Autodesk CLD import option to allow importing of Fusion toolpaths from a human readable text file.

CAMCustomStrategyManager : Base
  # Base class object representing all operations, folders, patterns and setups.
  deregisterCustomOperationByStrategyName(strategyName: str) -> bool
  deregisterCustomOperationsByAddinName(addinName: str) -> bool
  registerCustomOperation(input: CustomOperationDefinitionInput) -> CustomOperationRegistrationResult
  registerCustomOperations(inputs: list[CustomOperationDefinitionInput]) -> CustomOperationRegistrationResult]

CAMEventArgs : Base
  # The OperationEventArgs provides information associated with an operation event.
  info: str

CAMEventManager : Base
  operationBaseChanged: OperationBaseEvent
  operationBaseCommandButtonPressed: OperationBaseEvent
  operationBaseCommandStarted: OperationBaseEvent
  operationBaseGenerationStarted: OperationBaseEvent
  operationBaseGenerationStarting: OperationBaseEvent

CAMExportFuture : Base
  # Used to check the state and get back the results of an operation generation.
  error: str
  exportOptions: CAMExportOptions
  isGenerationCompleted: bool
  progress: float
  warning: str

CAMExportManager : Base
  create3MFOptions() -> CAM3MFExportOptions
  createAutodeskCLDExportOptions() -> CAMAutodeskCLDExportOptions
  createCAMAdditiveBuildExportOptions() -> CAMAdditiveBuildExportOptions
  createFormlabsOptions() -> CAMFormlabsExportOptions
  createPRMExportOptions() -> PRMExportOptions
  execute(exportOptions: CAMExportOptions) -> bool
  executeWithExportFuture(exportOptions: CAMExportOptions) -> CAMExportFuture

CAMExportOptions : Base
  error: str
  exportObject: Base
  fullFilename: str
  isThumbnailSupported: bool
  thumbnailPath: str

CAMFolder : OperationBase
  # Object that represents a folder in an existing Setup, Folder or Pattern.
  allOperations: ObjectCollection
  children: ChildOperationList
  folders: CAMFolders
  isActive: bool
  operations: Operations
  parent: Base
  patterns: CAMPatterns
  activate() -> bool
  copyAfter(operation: OperationBase) -> bool
  copyBefore(operation: OperationBase) -> bool
  copyInto(container: OperationBase) -> bool
  createFromCAMTemplate(camTemplate: CAMTemplate) -> OperationBase]
  createFromCAMTemplate2(input: CreateFromCAMTemplateInput) -> OperationBase]
  createFromTemplate(templateFilePath: str) -> ObjectCollection
  createFromTemplateXML(templateXML: str) -> OperationBase]
  deleteMe() -> bool
  duplicate() -> bool
  hasMissingReferences() -> bool
  modifyUtility(utility: ModifyUtilityTypes) -> ModifyUtility
  moveAfter(operation: OperationBase) -> bool
  moveBefore(operation: OperationBase) -> bool
  moveInto(container: OperationBase) -> bool
  removeReferences(entity: Base, removeFromChildren: bool) -> bool

CAMFolders *collection<CAMFolder>
  # Collection that provides access to the folders within an existing setup, folder or pattern.
  count: int
  addFolder(name: str) -> CAMFolder
  itemByName(name: str) -> CAMFolder
  itemByOperationId(id: int) -> CAMFolder

CAMFormlabsExportOptions : CAMExportOptions
  areSupportsIncluded: bool
  isVolumetricDataIncluded: bool
  volumetricDataResolution: int

CAMHoleRecognition : OperationBase
  # Object that represents a hole recognition object in an existing Setup, Folder or Pattern.
