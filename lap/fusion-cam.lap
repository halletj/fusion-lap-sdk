  createGoldakCard(efficiency: float, bAxisMultiplier: float, c1AxisMultiplier: float, c2AxisMultiplier: float, f1Factor: float, f2Factor: float) -> AdditiveFEADeckBuilderCard
  createIntCard(card: AdditiveFEACard, value: int) -> AdditiveFEADeckBuilderCard
  createLaserPathGenerationCard(power: float, radius: float, speed: float, thickness: float, hatch: float, recoaterTime: float, layerCount: int, initialAngle: float, angleChange: float, xSize: float, ySize: float) -> AdditiveFEADeckBuilderCard
  createMaterialCard(material: AdditiveFEAMaterial, materialId: int) -> AdditiveFEADeckBuilderCard
  createMechanicalRelaxationCard(isUsed: int, maxIterations: int, scalingFactor: float) -> AdditiveFEADeckBuilderCard
  createPropertyScalingCard(conductivityScaling: float, specificHeatScaling: float, elasticModulusScaling: float, emissivityScaling: float) -> AdditiveFEADeckBuilderCard
  createRelaxationCard(iterations: int, scalingFactor: float) -> AdditiveFEADeckBuilderCard
  createSTLMap() -> AdditiveFEASTLMap
  createSTLMapCard(map: AdditiveFEASTLMap) -> AdditiveFEADeckBuilderCard
  createSolutionParametersCard(maxIterations: int, tolerance: float, maxResidual: float) -> AdditiveFEADeckBuilderCard
  createStringArrayCard(card: AdditiveFEACard, value: list[str]) -> AdditiveFEADeckBuilderCard
  createStringCard(card: AdditiveFEACard, value: str) -> AdditiveFEADeckBuilderCard
  createTransientCard(startTime: float, endTime: float, initialTimeIncrement: float, maxTimeIncrement: float, minTimeIncrement: float, incrementTol: float, maxCutbacks: int, maxIncrements: int) -> AdditiveFEADeckBuilderCard
  createVoidCard(card: AdditiveFEACard) -> AdditiveFEADeckBuilderCard

