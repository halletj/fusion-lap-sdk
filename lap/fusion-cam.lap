  moveBefore(operation: OperationBase) -> bool
  moveInto(container: OperationBase) -> bool
  removeReferences(entity: Base, removeFromChildren: bool) -> bool

CAMImportManager : Base
  # Import manager used to import data into the selected setup.
  createAutodeskCLDImportOptions() -> CAMAutodeskCLDImportOptions
  execute(importOptions: CAMImportOptions) -> bool

CAMImportOptions : Base
  # Parent class for all ImportOptions objects giving access to the setup.
  fullFilename: str
  importObject: Base

CAMInspectionResults *collection<CAMMeasure>
  # Collection that provides access to the Measures in a results folder.
  count: int
  itemByName(name: str) -> CAMMeasure

CAMLibrary : Base
  # The CAMLibrary is the base-class for all other asset-specific libraries.
  assetTypeName: str
  childAssetURLs(url: URL) -> URL]
  childFolderURLs(url: URL) -> URL]
  createFolder(parentUrl: URL, folderName: str) -> URL
  deleteAsset(url: URL) -> bool
  deleteFolder(url: URL) -> bool
  displayName(url: URL) -> str
  doesPathExist(url: URL) -> bool
  urlByLocation(location: LibraryLocations) -> URL

CAMLibraryManager : Base
  fusion360MachineFolder: str
  fusion360PostFolder: str
  localMachineFolder: str
  localPostFolder: str
  machineLibrary: MachineLibrary
  networkMachineFolder: str
  postLibrary: PostLibrary
  printSettingLibrary: PrintSettingLibrary
  stockMaterialLibrary: StockMaterialLibrary
  templateLibrary: CAMTemplateLibrary
  toolLibraries: ToolLibraries

CAMManager : Base
  camEventManager: CAMEventManager
  customStrategyManager: CAMCustomStrategyManager
  libraryManager: CAMLibraryManager
  networkMachineIntegrationManager: NetworkMachineIntegrationManager
  postEnginePath: str
