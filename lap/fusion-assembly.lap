# fusion-assembly.lap

[types]
JointDirections: XAxisJointDirection | YAxisJointDirection | ZAxisJointDirection | CustomJointDirection
JointGeometryTypes: JointConstructionPointGeometry | JointSketchPointGeometry | JointBRepVertexGeometry | JointBRepEdgeGeometry | JointSketchCurveGeometry | JointProfileGeometry | JointPlanarBRepFaceGeometry | JointNonPlanarBRepFaceGeometry | JointBetweenTwoPlanesGeometry | JointByTwoEdgeIntersectionGeometry | JointTangentBRepFaceGeometry | JointTangentBRepFaceEdgeGeometry
JointKeyPointTypes: StartKeyPoint | MiddleKeyPoint | EndKeyPoint | CenterKeyPoint
JointMotionTypes: BallJointPitchMotionType | BallJointRollMotionType | BallJointYawMotionType | CylindricalJointRotateMotionType | CylindricalJointSlideMotionType | PinSlotJointRotateMotionType | PinSlotJointSlideMotionType | PlanarJointRotateMotionType | PlanarJointSlideOneMotionType | PlanarJointSlideTwoMotionType | RevoluteJointRotateMotionType | SliderJointSlideMotionType
JointQuadrantAngleTypes: StartJointQuadrantAngleType | QuarterJointQuadrantAngleType | MiddleJointQuadrantAngleType | ThirdQuarterJointQuadrantAngleType
JointTangentFaceEdgePointTypes: StartJointTangentFaceEdgePointType | QuarterJointTangentFaceEdgePointType | MiddleJointTangentFaceEdgePointType | ThirdQuarterJointTangentFaceEdgePointType | EndJointTangentFaceEdgePointType
JointTangentFaceTypes: NoneJointTangentFaceType | CylinderOrConeJointTangentFaceType | SphereJointTangentFaceType | TorusJointTangentFaceType | SplineJointTangentFaceType
JointTypes: RigidJointType | RevoluteJointType | SliderJointType | CylindricalJointType | PinSlotJointType | PlanarJointType | BallJointType | InferredJointType

[classes]
AsBuiltJoint : Base
  # Represent an as-built joint.
  assemblyContext: Occurrence
  attributes: Attributes
  entityToken: str
  geometry: JointGeometry
  isLightBulbOn: bool
  isSuppressed: bool
  isVisible: bool
  jointMotion: JointMotion
  motionLinks: MotionLink]
  name: str
  nativeObject: AsBuiltJoint
  occurrenceOne: Occurrence
  occurrenceTwo: Occurrence
  parentComponent: Component
  timelineObject: TimelineObject
  transform: Matrix3D
  createForAssemblyContext(occurrence: Occurrence) -> AsBuiltJoint
  deleteMe() -> bool
  setAsBallJointMotion() -> bool
  setAsCylindricalJointMotion() -> bool
  setAsPinSlotJointMotion() -> bool
  setAsPlanarJointMotion() -> bool
  setAsRevoluteJointMotion() -> bool
  setAsRigidJointMotion() -> bool
  setAsSliderJointMotion() -> bool

AsBuiltJointInput : Base
  # Defines all of the information needed to create an as-built joint.
  geometry: JointGeometry
  jointMotion: JointMotion
  occurrenceOne: Occurrence
  occurrenceTwo: Occurrence
  setAsBallJointMotion() -> bool
  setAsCylindricalJointMotion() -> bool
  setAsPinSlotJointMotion() -> bool
  setAsPlanarJointMotion() -> bool
  setAsRevoluteJointMotion() -> bool
  setAsRigidJointMotion() -> bool
  setAsSliderJointMotion() -> bool

AsBuiltJointList *collection<AsBuiltJoint>
  # A list of as-built joints.
  count: int
  itemByName(name: str) -> AsBuiltJoint

AsBuiltJointVector
  append(x: AsBuiltJoint) -> void
  assign(n: std::vector< adsk::core::Ptr< adsk::fusion::AsBuiltJoint > >::size_type, x: AsBuiltJoint) -> void
  back() -> AsBuiltJoint >::value_type
  begin() -> AsBuiltJoint >::iterator
  capacity() -> AsBuiltJoint >::size_type
  clear() -> void
  empty() -> bool
  end() -> AsBuiltJoint >::iterator
  erase() -> AsBuiltJoint >::iterator
  front() -> AsBuiltJoint >::value_type
  get_allocator() -> AsBuiltJoint >::allocator_type
  insert() -> void
  iterator() -> swig::SwigPyIterator
  pop() -> AsBuiltJoint >::value_type
  pop_back() -> void
  push_back(x: AsBuiltJoint) -> void
  rbegin() -> AsBuiltJoint >::reverse_iterator
  rend() -> AsBuiltJoint >::reverse_iterator
  reserve(n: std::vector< adsk::core::Ptr< adsk::fusion::AsBuiltJoint > >::size_type) -> void
  resize() -> void
  size() -> AsBuiltJoint >::size_type
  swap(v: list[AsBuiltJoint]) -> void

AsBuiltJoints *collection<AsBuiltJoint>
  count: int
  add(input: AsBuiltJointInput) -> AsBuiltJoint
  createInput(occurrenceOne: Occurrence, occurrenceTwo: Occurrence, geometry: JointGeometry) -> AsBuiltJointInput
  itemByName(name: str) -> AsBuiltJoint

BallJointMotion : JointMotion
  # Represents the set of information specific to a ball joint.
  customPitchDirectionEntity: Base
  customYawDirectionEntity: Base
  pitchDirection: JointDirections
  pitchDirectionVector: Vector3D
  pitchLimits: JointLimits
  pitchValue: float
  rollDirectionVector: Vector3D
  rollLimits: JointLimits
  rollValue: float
  yawDirection: JointDirections
  yawDirectionVector: Vector3D
  yawLimits: JointLimits
  yawValue: float

Component : BaseComponent
  activeSheetMetalRule: SheetMetalRule
