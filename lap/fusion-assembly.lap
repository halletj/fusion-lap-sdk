  setOccurrences(occurrences: ObjectCollection, includeChildren: bool) -> bool

RigidJointMotion : JointMotion

SliderJointMotion : JointMotion
  # Represents the set of information specific to a slider joint.
  customSlideDirectionEntity: Base
  slideDirection: JointDirections
  slideDirectionVector: Vector3D
  slideLimits: JointLimits
  slideValue: float
