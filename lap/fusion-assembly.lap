  revisionId: str
  rigidGroups: RigidGroups
  sketches: Sketches
  tangentRelationships: TangentRelationships
  xConstructionAxis: ConstructionAxis
  xYConstructionPlane: ConstructionPlane
  xZConstructionPlane: ConstructionPlane
  yConstructionAxis: ConstructionAxis
  yZConstructionPlane: ConstructionPlane
  zConstructionAxis: ConstructionAxis
  allOccurrencesByComponent(component: Component) -> OccurrenceList
  boundingBox2(entityTypes: BoundingBoxEntityTypes) -> BoundingBox3D
  createBRepEdgeProfile(edges: Base, chainEdges: bool) -> Profile
  createFlatPattern(stationaryFace: BRepFace) -> FlatPattern
  createOpenProfile(curves: Base, chainCurves: bool) -> Profile
  createThumbnail() -> DataObject
  findBRepUsingPoint(point: Point3D, entityType: BRepEntityTypes, proximityTolerance: float, visibleEntitiesOnly: bool) -> ObjectCollection
  findBRepUsingRay() -> ObjectCollection
  getPhysicalProperties() -> PhysicalProperties
  internalCommand(commandName: str, commandArgs: list[str]) -> str
  occurrencesByComponent(component: Component) -> OccurrenceList
  saveCopyAs(name: str, dataFolder: DataFolder, description: str, tag: str) -> DataFileFuture
  transformOccurrences(occurrences: list[Occurrence], transforms: list[Matrix3D], ignoreJoints: bool) -> bool

ConfigurationJointSnap : Base
  jointGeometry: Base
