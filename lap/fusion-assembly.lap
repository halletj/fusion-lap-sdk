Occurrence : Base
  # Represents an occurrence of a component at any level within a subassembly.
  appearance: Appearance
  asBuiltJoints: AsBuiltJointList
  assemblyContext: Occurrence
  attributes: Attributes
  bRepBodies: BRepBodies
  boundingBox: BoundingBox3D
  childOccurrences: OccurrenceList
  component: Component
  configurationRow: ConfigurationRow
  configuredDataFile: DataFile
  dataComponent: DataComponent
  deriveFeature: DeriveFeature
  documentReference: DocumentReference
  entityToken: str
  fullPathName: str
  initialTransform: Matrix3D
  isActive: bool
  isConfiguration: bool
  isDerived: bool
  isGroundToParent: bool
  isGrounded: bool
  isIsolated: bool
  isLightBulbOn: bool
  isReferencedComponent: bool
  isSelectable: bool
  isVaildForEditInitialPosition: bool
  isVisible: bool
  joints: JointList
  meshBodies: MeshBody]
  name: str
  nativeObject: Occurrence
  orientedMinimumBoundingBox: OrientedBoundingBox3D
  physicalProperties: PhysicalProperties
  preciseBoundingBox: BoundingBox3D
  rigidGroups: RigidGroupList
  sourceComponent: Component
  timelineObject: TimelineObject
  transform: Matrix3D
  transform2: Matrix3D
  visibleOpacity: float
  activate() -> bool
  boundingBox2(entityTypes: BoundingBoxEntityTypes) -> BoundingBox3D
  breakLink() -> bool
  createForAssemblyContext(occurrence: Occurrence) -> Occurrence
  deleteMe() -> bool
  getPhysicalProperties() -> PhysicalProperties
  moveToComponent(targetOccurrence: Occurrence) -> Occurrence
  replace(newFile: DataFile, replaceAll: bool) -> bool
  switchConfiguration(newRow: ConfigurationRow) -> bool

PinSlotJointMotion : JointMotion
  # Represents the set of information specific to a pin slot joint.
  customRotationAxisEntity: Base
  customSlideDirectionEntity: Base
  rotationAxis: JointDirections
  rotationAxisVector: Vector3D
  rotationLimits: JointLimits
  rotationValue: float
  slideDirection: JointDirections
  slideDirectionVector: Vector3D
  slideLimits: JointLimits
  slideValue: float

PlanarJointMotion : JointMotion
  # Represents the set of information specific to a planar joint.
  customNormalDirectionEntity: Base
  customPrimarySlideDirectionEntity: Base
  normalDirection: JointDirections
  normalDirectionVector: Vector3D
