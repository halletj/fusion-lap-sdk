  primarySlideDirectionVector: Vector3D
  primarySlideLimits: JointLimits
  primarySlideValue: float
  rotationLimits: JointLimits
  rotationValue: float
  secondarySlideDirectionVector: Vector3D
  secondarySlideLimits: JointLimits
  secondarySlideValue: float

RevoluteJointMotion : JointMotion
  # Represents the set of information specific to a revolute joint.
  customRotationAxisEntity: Base
  rotationAxis: JointDirections
  rotationAxisVector: Vector3D
  rotationLimits: JointLimits
  rotationValue: float

RigidGroup : Base
  # Represents a rigid group within an assembly.
  assemblyContext: Occurrence
  attributes: Attributes
  entityToken: str
  isSuppressed: bool
  isVisible: bool
  name: str
  nativeObject: RigidGroup
  occurrences: OccurrenceList
  parentComponent: Component
  timelineObject: TimelineObject
