  setAsPlanarJointMotion() -> bool
  setAsRevoluteJointMotion() -> bool
  setAsRigidJointMotion() -> bool
  setAsSliderJointMotion() -> bool

JointLimits : Base
  # Used to define limits for the range of motion of a joint.
  isMaximumValueEnabled: bool
  isMinimumValueEnabled: bool
  isRestValueEnabled: bool
  maximumValue: float
  minimumValue: float
  restValue: float

JointList *collection<Joint>
