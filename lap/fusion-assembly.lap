  healthState: FeatureHealthStates
  isFlipped: bool
  isLightBulbOn: bool
  isLocked: bool
  isSuppressed: bool
  isVisible: bool
  jointMotion: JointMotion
  motionLinks: MotionLink]
  name: str
  nativeObject: Joint
  occurrenceOne: Occurrence
  occurrenceTwo: Occurrence
  offset: ModelParameter
  offsetX: ModelParameter
  offsetY: ModelParameter
  parentComponent: Component
  timelineObject: TimelineObject
  createForAssemblyContext(occurrence: Occurrence) -> Joint
  deleteMe() -> bool
  setAsBallJointMotion() -> bool
  setAsCylindricalJointMotion() -> bool
  setAsPinSlotJointMotion() -> bool
  setAsPlanarJointMotion() -> bool
  setAsRevoluteJointMotion() -> bool
  setAsRigidJointMotion() -> bool
  setAsSliderJointMotion() -> bool

JointGeometry : Base
  entityOne: Base
  entityTwo: Base
  geometryType: JointGeometryTypes
  keyPointType: JointKeyPointTypes
  origin: Point3D
  planeOne: Base
  planeTwo: Base
  primaryAxisVector: Vector3D
  secondaryAxisVector: Vector3D
  tangentFaceParamOne: float
  tangentFaceParamTwo: float
  tangentFaceType: JointTangentFaceTypes
  thirdAxisVector: Vector3D
  @static createByBetweenTwoPlanes(planeOne: Base, planeTwo: Base, entityOne: Base, entityTwo: Base, keyPointType: JointKeyPointTypes) -> JointGeometry
  @static createByCurve(curve: Base, keyPointType: JointKeyPointTypes) -> JointGeometry
  @static createByCylinderOrConeFace(face: BRepFace, angle: JointQuadrantAngleTypes, height: JointKeyPointTypes) -> BRepFace
  @static createByNonPlanarFace(face: BRepFace, keyPointType: JointKeyPointTypes) -> BRepFace
  @static createByPlanarFace(face: BRepFace, edge: BRepEdge, keyPointType: JointKeyPointTypes) -> BRepEdge
  @static createByPoint(point: Base) -> JointGeometry
  @static createByProfile(profile: Profile, sketchCurve: SketchCurve, keyPointType: JointKeyPointTypes) -> SketchCurve
  @static createBySphereFace(face: BRepFace, azimuthAngle: JointQuadrantAngleTypes, polarAngle: JointKeyPointTypes) -> BRepFace
  @static createBySplineFace(face: BRepFace, paramU: JointKeyPointTypes, paramV: JointKeyPointTypes) -> BRepFace
  @static createByTangentFaceEdge(face: BRepFace, edge: BRepEdge, edgePointType: JointTangentFaceEdgePointTypes) -> BRepEdge
  @static createByTorusFace(face: BRepFace, azimuthAngle: JointQuadrantAngleTypes, sectionAngle: JointQuadrantAngleTypes) -> BRepFace
  @static createByTwoEdgeIntersection(edgeOne: BRepEdge, edgeTwo: BRepEdge) -> BRepEdge

JointInput : Base
  angle: ValueInput
  geometryOrOriginOne: Base
  geometryOrOriginTwo: Base
  isFlipped: bool
