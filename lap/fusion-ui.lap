  inputChanged: InputChangedEvent
  isAutoExecute: bool
  isExecutedWhenPreEmpted: bool
  isOKButtonVisible: bool
  isPositionDependent: bool
  isRepeatable: bool
  keyDown: KeyboardEvent
  keyUp: KeyboardEvent
  mouseClick: MouseEvent
  mouseDoubleClick: MouseEvent
  mouseDown: MouseEvent
  mouseDrag: MouseEvent
  mouseDragBegin: MouseEvent
  mouseDragEnd: MouseEvent
  mouseMove: MouseEvent
  mouseUp: MouseEvent
  mouseWheel: MouseEvent
