  commandId: str
  isCanceled: bool
  terminationReason: CommandTerminationReason

ApplicationCommandEventHandler
  notify(eventArgs: ApplicationCommandEventArgs) -> void

ApplicationEvent : Event
  add(handler: ApplicationEventHandler) -> bool
  remove(handler: ApplicationEventHandler) -> bool

ApplicationEventArgs : EventArgs
