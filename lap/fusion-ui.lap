# fusion-ui.lap

[types]
CAMEventChangeType: ErrorCAMEventChangeType | ToolCAMEventChangeType | ToolSwitchCAMEventChangeType | NameCAMEventChangeType | ParameterCAMEventChangeType
CAMEventState: CAMEventStateSuccessful | CAMEventStateDeferred | CAMEventStateErrorMissingOperation | CAMEventStateErrorMissingDocument | CAMEventStateErrorOther
OperationBaseEventTypes: ErrorOperationBaseEventType | CommandStartedOperationBaseEventType | GenerationStartedOperationBaseEventType | ChangeOperationBaseEventType | GenerationStartingOperationBaseEventType | CommandButtonPressedOperationBaseEventType
SetupChangeEventType: Arbitrary | PrintSettingSelection

[classes]
ActiveSelectionEvent : Event
  add(handler: ActiveSelectionEventHandler) -> bool
  remove(handler: ActiveSelectionEventHandler) -> bool

ActiveSelectionEventArgs : EventArgs
  currentSelection: Selection]

ActiveSelectionEventHandler
  notify(eventArgs: ActiveSelectionEventArgs) -> void

AngleValueCommandInput : CommandInput
  expression: str
  hasMaximumValue: bool
  hasMinimumValue: bool
  isMaximumValueInclusive: bool
  isMinimumValueInclusive: bool
  isValidExpression: bool
  manipulatorOrigin: Point3D
  manipulatorXDirection: Vector3D
  manipulatorYDirection: Vector3D
  maximumValue: float
  minimumValue: float
  value: float
  deleteMe() -> bool
  setManipulator(origin: Point3D, xDirection: Vector3D, yDirection: Vector3D) -> bool

ApplicationCommandEvent : Event
  # An event endpoint that supports the connection to ApplicationCommandEventHandlers.
  add(handler: ApplicationCommandEventHandler) -> bool
  remove(handler: ApplicationCommandEventHandler) -> bool

ApplicationCommandEventArgs : EventArgs
