  preSelect: SelectionEvent
  preSelectEnd: SelectionEvent
  preSelectMouseMove: SelectionEvent
  preSelectStart: SelectionEvent
  select: SelectionEvent
  selectionEvent: SelectionEvent
  unselect: SelectionEvent
