  setCursor(cursorImage: str, xHotSpot: int, yHotSpot: int) -> bool
  setDialogInitialSize(width: int, height: int) -> bool
  setDialogMinimumSize(width: int, height: int) -> bool
  setDialogSize(width: int, height: int) -> bool

CommandCreatedEvent : Event
  # Class that needs to be implemented in order to respond to the CommandCreatedEvent event.
  add(handler: CommandCreatedEventHandler) -> bool
  remove(handler: CommandCreatedEventHandler) -> bool

CommandCreatedEventArgs : EventArgs
  # Provides data for the CommandCreated event.
  command: Command

CommandCreatedEventHandler
  notify(eventArgs: CommandCreatedEventArgs) -> void

CommandEvent : Event
  # An event endpoint that supports the connection to client implemented CommandEventHandlers.
  add(handler: CommandEventHandler) -> bool
  remove(handler: CommandEventHandler) -> bool

CommandEventArgs : EventArgs
  command: Command
  executeFailed: bool
  executeFailedMessage: str
  isValidResult: bool
  terminationReason: CommandTerminationReason

CommandEventHandler
  notify(eventArgs: CommandEventArgs) -> void

CommandInput : Base
  commandInputs: CommandInputs
  id: str
  isEnabled: bool
  isFullWidth: bool
  isVisible: bool
  name: str
  parentCommand: Command
  parentCommandInput: CommandInput
  toolClipFilename: str
  tooltip: str
  tooltipDescription: str
  deleteMe() -> bool

CommandInputs *collection<CommandInput>
  command: Command
  count: int
  addAngleValueCommandInput(id: str, name: str, initialValue: ValueInput) -> AngleValueCommandInput
  addBoolValueInput() -> BoolValueCommandInput
  addBrowserCommandInput(id: str, name: str, htmlFileURL: str, minimumHeight: int, maximumHeight: int) -> BrowserCommandInput
  addButtonRowCommandInput(id: str, name: str, isMultiSelectEnabled: bool) -> ButtonRowCommandInput
  addDirectionCommandInput() -> DirectionCommandInput
  addDistanceValueCommandInput(id: str, name: str, initialValue: ValueInput) -> DistanceValueCommandInput
  addDropDownCommandInput(id: str, name: str, dropDownStyle: DropDownStyles) -> DropDownCommandInput
  addFloatSliderCommandInput(id: str, name: str, unitType: str, min: float, max: float, hasTwoSliders: bool) -> FloatSliderCommandInput
  addFloatSliderListCommandInput(id: str, name: str, unitType: str, valueList: list[float], hasTwoSliders: bool) -> FloatSliderCommandInput
  addFloatSpinnerCommandInput(id: str, name: str, unitType: str, min: float, max: float, spinStep: float, initialValue: float) -> FloatSpinnerCommandInput
  addGroupCommandInput(id: str, name: str) -> GroupCommandInput
  addImageCommandInput(id: str, name: str, imageFile: str) -> ImageCommandInput
  addIntegerSliderCommandInput(id: str, name: str, min: int, max: int, hasTwoSliders: bool) -> IntegerSliderCommandInput
  addIntegerSliderListCommandInput(id: str, name: str, valueList: list[int], hasTwoSliders: bool) -> IntegerSliderCommandInput
  addIntegerSpinnerCommandInput(id: str, name: str, min: int, max: int, spinStep: int, initialValue: int) -> IntegerSpinnerCommandInput
  addRadioButtonGroupCommandInput() -> RadioButtonGroupCommandInput
  addSelectionInput(id: str, name: str, commandPrompt: str) -> SelectionCommandInput
  addSeparatorCommandInput(id: str) -> SeparatorCommandInput
  addStringValueInput() -> StringValueCommandInput
  addTabCommandInput() -> TabCommandInput
  addTableCommandInput(id: str, name: str, numberOfColumns: int, columnRatio: str) -> TableCommandInput
  addTextBoxCommandInput(id: str, name: str, formattedText: str, numRows: int, isReadOnly: bool) -> TextBoxCommandInput
  addTriadCommandInput(id: str, transform: Matrix3D) -> TriadCommandInput
  addValueInput(id: str, name: str, unitType: str, initialValue: ValueInput) -> ValueCommandInput
  itemById(id: str) -> CommandInput

