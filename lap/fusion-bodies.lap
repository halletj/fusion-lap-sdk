BRepLoop : Base
  # Represents a connected portion of a BRepFace boundary. It consists of a chain of BRepCoEdges.
  assemblyContext: Occurrence
  body: BRepBody
  boundingBox: BoundingBox3D
  coEdges: BRepCoEdges
  edges: BRepEdges
  entityToken: str
  face: BRepFace
  isOuter: bool
