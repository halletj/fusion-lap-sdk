BRepLump : Base
  # Represents an entirely connected set of entities. A BRepBody consists of BRepLumps.
  area: float
  assemblyContext: Occurrence
  body: BRepBody
  boundingBox: BoundingBox3D
  edges: BRepEdges
  entityToken: str
  faces: BRepFaces
  isClosed: bool
  meshManager: MeshManager
  nativeObject: BRepLump
  shells: BRepShells
  vertices: BRepVertices
  volume: float
  createForAssemblyContext(occurrence: Occurrence) -> BRepLump
  pointContainment(point: Point3D) -> PointContainment

BRepLumpDefinition : Base
  # Represents the definition of a B-Rep lump which is used in defining the topology of a B-Rep body.
  shellDefinitions: BRepShellDefinitions

BRepLumpDefinitions *collection<BRepLumpDefinition>
  count: int
  add() -> BRepLumpDefinition

BRepLumps *collection<BRepLump>
  # BRepLump collection.
  count: int

BRepShell : Base
  # Represents an entirely connected set of BRepFaces. A BRepLump may contain multiple BRepShells.
  area: float
  assemblyContext: Occurrence
  body: BRepBody
  boundingBox: BoundingBox3D
  edges: BRepEdges
  entityToken: str
  faces: BRepFaces
  isClosed: bool
  isVoid: bool
  lump: BRepLump
  meshManager: MeshManager
  nativeObject: BRepShell
  vertices: BRepVertices
  volume: float
  wire: BRepWire
  createForAssemblyContext(occurrence: Occurrence) -> BRepShell
  pointContainment(point: Point3D) -> PointContainment

BRepShellDefinition : Base
  faceDefinitions: BRepFaceDefinitions
  wireDefinition: BRepWireDefinition

BRepShellDefinitions *collection<BRepShellDefinition>
  count: int
  add() -> BRepShellDefinition

BRepShells *collection<BRepShell>
  # BRepShell collection.
  count: int

BRepVertex : Base
  # A 0-dimensional topological entity that bounds a BRepEdge.
  assemblyContext: Occurrence
