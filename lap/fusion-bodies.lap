  createForAssemblyContext(occurrence: Occurrence) -> BRepLoop

BRepLoopDefinition : Base
  bRepCoEdgeDefinitions: BRepCoEdgeDefinitions

BRepLoopDefinitions *collection<BRepLoopDefinition>
