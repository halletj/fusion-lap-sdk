  pop() -> BRepEdge >::value_type
  pop_back() -> void
  push_back(x: BRepEdge) -> void
  rbegin() -> BRepEdge >::reverse_iterator
  rend() -> BRepEdge >::reverse_iterator
  reserve(n: std::vector< adsk::core::Ptr< adsk::fusion::BRepEdge > >::size_type) -> void
  resize() -> void
  size() -> BRepEdge >::size_type
  swap(v: list[BRepEdge]) -> void

BRepEdges *collection<BRepEdge>
  # BRepEdge collection.
  count: int

BRepFace : Base
  # Represent a connected region on a single geometric surface.
