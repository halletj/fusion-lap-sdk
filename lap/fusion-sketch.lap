  split(splitPoint: Point3D, createConstraints: bool) -> ObjectCollection
  trim(segmentPoint: Point3D, createConstraints: bool) -> ObjectCollection

SketchConicCurves *collection<SketchConicCurve>
  count: int
  add(startPoint: Base, endPoint: Base, apexPoint: Base, rhoValue: float) -> SketchConicCurve

