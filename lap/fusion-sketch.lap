  createForAssemblyContext(occurrence: Occurrence) -> SketchCircle
  deleteMe() -> bool
  extend(endPoint: Point3D, createConstraints: bool) -> ObjectCollection
  intersections(sketchCurves: ObjectCollection) -> bool
  split(splitPoint: Point3D, createConstraints: bool) -> ObjectCollection
  trim(segmentPoint: Point3D, createConstraints: bool) -> ObjectCollection

SketchCircles *collection<SketchCircle>
  count: int
  addByCenterRadius(centerPoint: Base, radius: float) -> SketchCircle
  addByThreePoints(pointOne: Point3D, pointTwo: Point3D, pointThree: Point3D) -> SketchCircle
  addByThreeTangents(tangentOne: SketchLine, tangentTwo: SketchLine, tangentThree: SketchLine, hintPoint: Point3D) -> SketchCircle
  addByTwoPoints(pointOne: Point3D, pointTwo: Point3D) -> SketchCircle
  addByTwoTangents(tangentOne: SketchLine, tangentTwo: SketchLine, radius: float, hintPoint: Point3D) -> SketchCircle

SketchConcentricCircleDimension : SketchDimension
  # A concentric circle dimension in a sketch.
  circleOne: SketchCurve
  circleTwo: SketchCurve
