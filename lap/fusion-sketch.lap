# fusion-sketch.lap

[types]
SketchCurveConstructionStates: ToggleSketchCurveConstructionState | ConstructionSketchCurveConstructionState | NormalSketchCurveConstructionState
SketchLineCenterlineStates: ToggleSketchLineCenterlineState | CenterlineSketchLineCenterlineState | NormalSketchLineCenterlineState

[classes]
AssemblyConstraint : Base
  # Represents an assembly constraint.
  assemblyContext: Occurrence
  attributes: Attributes
  entityToken: str
  errorOrWarningMessage: str
  geometricRelationships: GeometricRelationships
  healthState: FeatureHealthStates
  isLightBulbOn: bool
  isSuppressed: bool
  isVisible: bool
  name: str
  nativeObject: AssemblyConstraint
  parentComponent: Component
  timelineObject: TimelineObject
  createForAssemblyContext(occurrence: Occurrence) -> AssemblyConstraint
  deleteMe() -> bool

CircularPatternConstraint : GeometricConstraint
  # A circular pattern constraint in a sketch.
  centerPoint: SketchPoint
  createdEntities: SketchEntity]
  entities: SketchEntity]
  isSuppressed: list[bool]
  isSymmetric: bool
  nativeObject: CircularPatternConstraint
  quantity: ModelParameter
  totalAngle: ModelParameter
  createForAssemblyContext(occurrence: Occurrence) -> CircularPatternConstraint
  deleteMe() -> bool

CoincidentConstraint : GeometricConstraint
  # A coincident constraint in a sketch.
  entity: SketchEntity
  nativeObject: CoincidentConstraint
  point: SketchPoint
  createForAssemblyContext(occurrence: Occurrence) -> CoincidentConstraint
  deleteMe() -> bool

CoincidentToSurfaceConstraint : GeometricConstraint
  # A sketch constraint defining that a point is coincident to a surface.
  nativeObject: CoincidentToSurfaceConstraint
  point: SketchPoint
  surface: Base
  createForAssemblyContext(occurrence: Occurrence) -> CoincidentToSurfaceConstraint
  deleteMe() -> bool

CollinearConstraint : GeometricConstraint
  # A collinear constraint in a sketch.
  lineOne: SketchLine
  lineTwo: SketchLine
  nativeObject: CollinearConstraint
  createForAssemblyContext(occurrence: Occurrence) -> CollinearConstraint
  deleteMe() -> bool

ConcentricConstraint : GeometricConstraint
  # A concentric constraint in a sketch.
  entityOne: SketchCurve
  entityTwo: SketchCurve
  nativeObject: ConcentricConstraint
  createForAssemblyContext(occurrence: Occurrence) -> ConcentricConstraint
  deleteMe() -> bool

EqualConstraint : GeometricConstraint
  # An equal constraint in a sketch.
  curveOne: SketchCurve
  curveTwo: SketchCurve
  nativeObject: EqualConstraint
  createForAssemblyContext(occurrence: Occurrence) -> EqualConstraint
  deleteMe() -> bool

GeometricConstraint : Base
  # The base class for all geometric constraints.
  assemblyContext: Occurrence
  attributes: Attributes
  entityToken: str
  isDeletable: bool
  parentSketch: Sketch
  deleteMe() -> bool

GeometricConstraintList *collection<GeometricConstraint>
  # A list of geometric constraints.
  count: int

GeometricConstraintVector
  append(x: GeometricConstraint) -> void
  assign(n: std::vector< adsk::core::Ptr< adsk::fusion::GeometricConstraint > >::size_type, x: GeometricConstraint) -> void
  back() -> GeometricConstraint >::value_type
  begin() -> GeometricConstraint >::iterator
  capacity() -> GeometricConstraint >::size_type
  clear() -> void
  empty() -> bool
  end() -> GeometricConstraint >::iterator
  erase() -> GeometricConstraint >::iterator
  front() -> GeometricConstraint >::value_type
  get_allocator() -> GeometricConstraint >::allocator_type
  insert() -> void
  iterator() -> swig::SwigPyIterator
  pop() -> GeometricConstraint >::value_type
  pop_back() -> void
  push_back(x: GeometricConstraint) -> void
  rbegin() -> GeometricConstraint >::reverse_iterator
  rend() -> GeometricConstraint >::reverse_iterator
  reserve(n: std::vector< adsk::core::Ptr< adsk::fusion::GeometricConstraint > >::size_type) -> void
  resize() -> void
  size() -> GeometricConstraint >::size_type
  swap(v: list[GeometricConstraint]) -> void

GeometricConstraints *collection<GeometricConstraint>
  count: int
  addCircularPattern(input: CircularPatternConstraintInput) -> CircularPatternConstraint
  addCoincident(point: SketchPoint, entity: SketchEntity) -> CoincidentConstraint
  addCoincidentToSurface(point: SketchPoint, surface: Base) -> CoincidentToSurfaceConstraint
  addCollinear(lineOne: SketchLine, lineTwo: SketchLine) -> CollinearConstraint
  addConcentric(entityOne: SketchCurve, entityTwo: SketchCurve) -> ConcentricConstraint
  addEqual(curveOne: SketchCurve, curveTwo: SketchCurve) -> EqualConstraint
  addHorizontal(line: SketchLine) -> HorizontalConstraint
  addHorizontalPoints(pointOne: SketchPoint, pointTwo: SketchPoint) -> HorizontalPointsConstraint
  addLineOnPlanarSurface(line: SketchLine, planarSurface: Base) -> LineOnPlanarSurfaceConstraint
  addLineParallelToPlanarSurface(line: SketchLine, planarSurface: Base) -> LineParallelToPlanarSurfaceConstraint
  addMidPoint(point: SketchPoint, midPointCurve: SketchCurve) -> MidPointConstraint
  addOffset(curves: list[SketchCurve], offset: ValueInput, basePoint: Point3D) -> OffsetConstraint
  addOffset2(input: OffsetConstraintInput) -> OffsetConstraint
  addParallel(lineOne: SketchLine, lineTwo: SketchLine) -> ParallelConstraint
  addPerpendicular(lineOne: SketchLine, lineTwo: SketchLine) -> PerpendicularConstraint
  addPerpendicularToSurface(curve: SketchCurve, surface: Base) -> PerpendicularToSurfaceConstraint
  addPolygon(lines: list[SketchLine]) -> PolygonConstraint
  addRectangularPattern(input: RectangularPatternConstraintInput) -> RectangularPatternConstraint
  addSmooth(curveOne: SketchCurve, curveTwo: SketchCurve) -> SmoothConstraint
  addSymmetry(entityOne: SketchEntity, entityTwo: SketchEntity, symmetryLine: SketchLine) -> SymmetryConstraint
  addTangent(curveOne: SketchCurve, curveTwo: SketchCurve) -> TangentConstraint
  addTwoSidesOffset(input: OffsetConstraintInput, linkOffsets: bool) -> OffsetConstraint]
  addVertical(line: SketchLine) -> VerticalConstraint
  addVerticalPoints(pointOne: SketchPoint, pointTwo: SketchPoint) -> VerticalPointsConstraint
  createCircularPatternInput(inputEntities: list[SketchEntity], centerPoint: SketchPoint) -> CircularPatternConstraintInput
  createOffsetInput(curves: list[SketchCurve], offset: ValueInput) -> OffsetConstraintInput
  createRectangularPatternInput(entities: list[SketchEntity], distanceType: PatternDistanceType) -> RectangularPatternConstraintInput

HorizontalConstraint : GeometricConstraint
  # A horizontal constraint in a sketch.
  line: SketchLine
  nativeObject: HorizontalConstraint
  createForAssemblyContext(occurrence: Occurrence) -> HorizontalConstraint
  deleteMe() -> bool

HorizontalPointsConstraint : GeometricConstraint
  # A horizontal constraint between two points in a sketch.
  nativeObject: HorizontalPointsConstraint
  pointOne: SketchPoint
  pointTwo: SketchPoint
  createForAssemblyContext(occurrence: Occurrence) -> HorizontalPointsConstraint
  deleteMe() -> bool

LineOnPlanarSurfaceConstraint : GeometricConstraint
  # A sketch constraint defining that a line that lies on a planar face or construction plane.
  line: SketchLine
  nativeObject: LineOnPlanarSurfaceConstraint
  planarSurface: Base
  createForAssemblyContext(occurrence: Occurrence) -> LineOnPlanarSurfaceConstraint
  deleteMe() -> bool

LineParallelToPlanarSurfaceConstraint : GeometricConstraint
  # A sketch constraint defining that a line is parallel to a planar face or construction plane.
  line: SketchLine
  nativeObject: LineParallelToPlanarSurfaceConstraint
  planarSurface: Base
  createForAssemblyContext(occurrence: Occurrence) -> LineParallelToPlanarSurfaceConstraint
  deleteMe() -> bool

MidPointConstraint : GeometricConstraint
  # A midpoint constraint in a sketch.
  midPointCurve: SketchCurve
  nativeObject: MidPointConstraint
  point: SketchPoint
  createForAssemblyContext(occurrence: Occurrence) -> MidPointConstraint
  deleteMe() -> bool

OffsetConstraint : GeometricConstraint
  # An offset constraint in a sketch.
  childCurves: SketchCurve]
  dimension: SketchDimension
  distance: float
  isTopologyMatched: bool
  nativeObject: OffsetConstraint
  parentCurves: SketchCurve]
  createForAssemblyContext(occurrence: Occurrence) -> OffsetConstraint
  deleteMe() -> bool

ParallelConstraint : GeometricConstraint
  # A parallel constraint in a sketch.
  lineOne: SketchLine
  lineTwo: SketchLine
  nativeObject: ParallelConstraint
  createForAssemblyContext(occurrence: Occurrence) -> ParallelConstraint
  deleteMe() -> bool

PerpendicularConstraint : GeometricConstraint
  # A perpendicular constraint in a sketch.
  lineOne: SketchLine
  lineTwo: SketchLine
  nativeObject: PerpendicularConstraint
  createForAssemblyContext(occurrence: Occurrence) -> PerpendicularConstraint
  deleteMe() -> bool

PerpendicularToSurfaceConstraint : GeometricConstraint
  curve: SketchCurve
  nativeObject: PerpendicularToSurfaceConstraint
  surface: Base
  createForAssemblyContext(occurrence: Occurrence) -> PerpendicularToSurfaceConstraint
  deleteMe() -> bool

PolygonConstraint : GeometricConstraint
  # A polygon constraint in a sketch.
  centerPoint: SketchPoint
  lines: SketchLine]
  points: SketchPoint]
  deleteMe() -> bool

Profile : Base
  assemblyContext: Occurrence
  boundingBox: BoundingBox3D
  entityToken: str
  face: BRepFace
  nativeObject: Profile
  parentSketch: Sketch
  plane: Plane
  profileLoops: ProfileLoops
  areaProperties() -> AreaProperties
  createForAssemblyContext(occurrence: Occurrence) -> Profile

ProfileCurve : Base
  # A single curve in a profile.
  assemblyContext: Occurrence
  boundingBox: BoundingBox3D
  geometry: Curve3D
  geometryType: Curve3DTypes
  nativeObject: ProfileCurve
  parentProfile: Profile
  parentProfileLoop: ProfileLoop
  parentSketch: Sketch
  sketchEntity: SketchEntity
  createForAssemblyContext(occurrence: Occurrence) -> ProfileCurve

ProfileCurves *collection<ProfileCurve>
  # A collection of profile curves within a profile loop.
  count: int

ProfileLoop : Base
  # A loop within a profile.
  assemblyContext: Occurrence
  isOuter: bool
  nativeObject: ProfileLoop
  parentProfile: Profile
  profileCurves: ProfileCurves
  createForAssemblyContext(occurrence: Occurrence) -> ProfileLoop

ProfileLoops *collection<ProfileLoop>
  # A collection of loops within a Profile.
  count: int

ProfilePlaneStartDefinition : ExtentDefinition
  profilePlane: Plane
  @static create() -> ProfilePlaneStartDefinition

Profiles *collection<Profile>
  count: int

RectangularPatternConstraint : GeometricConstraint
  # A rectangular pattern constraint in a sketch.
  createdEntities: SketchEntity]
  directionOneEntity: SketchLine
  directionTwoEntity: SketchLine
  distanceOne: ModelParameter
  distanceTwo: ModelParameter
  distanceType: PatternDistanceType
  entities: SketchEntity]
  isSuppressed: list[bool]
  isSymmetricInDirectionOne: bool
  isSymmetricInDirectionTwo: bool
  nativeObject: RectangularPatternConstraint
  quantityOne: ModelParameter
  quantityTwo: ModelParameter
  createForAssemblyContext(occurrence: Occurrence) -> RectangularPatternConstraint
  deleteMe() -> bool
  setDirectionOne(directionOneEntity: SketchLine, quantityOne: ValueInput, distanceOne: ValueInput) -> bool
  setDirectionTwo(directionTwoEntity: SketchLine, quantityTwo: ValueInput, distanceTwo: ValueInput) -> bool

Sketch : Base
  # Represents a sketch within a component.
  areConstraintsShown: bool
  areDimensionsShown: bool
  arePointsShown: bool
  areProfilesShown: bool
  assemblyContext: Occurrence
  attributes: Attributes
  baseOrFormFeature: Base
  boundingBox: BoundingBox3D
  deriveFeature: DeriveFeature
  entityToken: str
  errorOrWarningMessage: str
  geometricConstraints: GeometricConstraints
  healthState: FeatureHealthStates
  isComputeDeferred: bool
  isConstructionGeometryShown: bool
  isDerived: bool
  isFullyConstrained: bool
  isLightBulbOn: bool
  isModelSliced: bool
  isParametric: bool
  isProjectedGeometryShown: bool
  isVisible: bool
  name: str
  nativeObject: Sketch
  origin: Point3D
  originPoint: SketchPoint
  parentComponent: Component
  profiles: Profiles
  referencePlane: Base
  revisionId: str
  sketchCurves: SketchCurves
  sketchDimensions: SketchDimensions
  sketchPoints: SketchPoints
  sketchTexts: SketchTexts
  timelineObject: TimelineObject
  transform: Matrix3D
  xDirection: Vector3D
  yDirection: Vector3D
  addCenterPointSlot() -> Base]
  addCenterToCenterSlot() -> Base]
  addOverallSlot() -> Base]
  autoConstrain(input: AutoConstrainInput) -> AutoConstrainResult
  copy() -> ObjectCollection
  createAutoConstrainInput() -> AutoConstrainInput
  createForAssemblyContext(occurrence: Occurrence) -> Sketch
  createSpunProfile(input: SpunProfileInput) -> SketchEntity]
  createSpunProfileInput(entities: list[Base], axis: Base) -> SpunProfileInput
  deleteMe() -> bool
  findConnectedCurves(curve: SketchCurve) -> ObjectCollection
  importSVG(fullFilename: str, xPosition: float, yPosition: float, scale: float) -> bool
  include(entity: Base) -> ObjectCollection
  intersectWithSketchPlane(entities: list[Base]) -> SketchEntity]
  modelToSketchSpace(modelCoordinate: Point3D) -> Point3D
  move(sketchEntities: ObjectCollection, transform: Matrix3D) -> bool
  offset(curves: ObjectCollection, directionPoint: Point3D, offset: float) -> ObjectCollection
  project(entity: Base) -> ObjectCollection
  project2(entities: list[Base], isLinked: bool) -> SketchEntity]
  projectCutEdges(body: BRepBody) -> ObjectCollection
  projectToSurface() -> SketchEntity]
  redefine(planarEntity: Base) -> bool
  saveAsDXF(fullFilename: str) -> bool
  setCenterlineState(sketchLines: list[SketchLine], centerlineState: SketchLineCenterlineStates) -> bool
  setConstructionState(sketchCurves: list[SketchCurve], constructionState: SketchCurveConstructionStates) -> bool
  sketchToModelSpace(sketchCoordinate: Point3D) -> Point3D

SketchAngularDimension : SketchDimension
  # An angular dimension in a sketch.
  lineOne: SketchLine
  lineTwo: SketchLine
  nativeObject: SketchAngularDimension
  createForAssemblyContext(occurrence: Occurrence) -> SketchAngularDimension
  deleteMe() -> bool

SketchArc : SketchCurve
  # An arc in a sketch.
  centerSketchPoint: SketchPoint
  endSketchPoint: SketchPoint
  geometry: Arc3D
  nativeObject: SketchArc
  radius: float
  startSketchPoint: SketchPoint
  worldGeometry: Arc3D
  breakCurve(segmentPoint: Point3D, createConstraints: bool) -> ObjectCollection
  createForAssemblyContext(occurrence: Occurrence) -> SketchArc
  deleteMe() -> bool
  extend(endPoint: Point3D, createConstraints: bool) -> ObjectCollection
  intersections(sketchCurves: ObjectCollection) -> bool
  split(splitPoint: Point3D, createConstraints: bool) -> ObjectCollection
  trim(segmentPoint: Point3D, createConstraints: bool) -> ObjectCollection

SketchArcs *collection<SketchArc>
  count: int
  addByCenterStartEnd() -> SketchArc
  addByCenterStartSweep(centerPoint: Base, startPoint: Base, sweepAngle: float) -> SketchArc
  addByThreePoints(startPoint: Base, point: Point3D, endPoint: Base) -> SketchArc
  addFillet(firstEntity: SketchCurve, firstEntityPoint: Point3D, secondEnitity: SketchCurve, secondEntityPoint: Point3D, radius: float) -> SketchArc

SketchCircle : SketchCurve
  # A circle in a sketch.
  area: float
  centerSketchPoint: SketchPoint
  geometry: Circle3D
  nativeObject: SketchCircle
  radius: float
  worldGeometry: Circle3D
