class Base:
    def classType() -> str: ...
    @property
    def isValid(self) -> bool: ...
    @property
    def objectType(self) -> str: ...

class Point3D(Base):
    @property
    def x(self) -> float: ...
    @x.setter
    def x(self, value: float) -> None: ...
    @property
    def y(self) -> float: ...
    @property
    def z(self) -> float: ...
    @staticmethod
    def create(x: float = 0, y: float = 0, z: float = 0) -> 'Point3D': ...

class Color(Base):
    @property
    def red(self) -> int: ...
    @property
    def green(self) -> int: ...
    @property
    def blue(self) -> int: ...
    @property
    def opacity(self) -> int: ...
    @staticmethod
    def create(red: int, green: int, blue: int, opacity: int) -> 'Color': ...
